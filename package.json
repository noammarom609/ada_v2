{
  "name": "dvirious",
  "version": "1.0.0",
  "description": "Dvirious - AI Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5180 && node electron/launch.js\"",
    "build": "vite build",
    "start": "npx electron .",
    "dist": "vite build && electron-builder --win",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:all": "vite build && electron-builder --win --mac --linux"
  },
  "keywords": [],
  "author": {
    "name": "Dvirious",
    "email": "noammarom609@gmail.com"
  },
  "license": "ISC",
  "build": {
    "appId": "com.jarvis.dvirious",
    "productName": "Dvirious",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "protocols": [
      {
        "name": "Dvirious Auth",
        "schemes": [
          "dvirious"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dvirious"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "noammarom609",
      "repo": "Dvirius"
    }
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "@react-three/drei": "^9.99.0",
    "@react-three/fiber": "^8.15.16",
    "@sentry/electron": "^7.9.0",
    "@types/three": "^0.160.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "posthog-js": "^1.359.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.4",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  }
}
